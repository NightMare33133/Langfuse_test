DIFY_API_KEY=
DIFY_API_BASE=http://localhost/v1

JUDGE_API_KEY=
JUDGE_API_BASE=https://token-plan-cn.xiaomimimo.com/v1
JUDGE_MODEL=mimo-v2.5-pro

# 题目生成（可选，默认复用 Judge 配置）
QGEN_API_KEY=
QGEN_API_BASE=
QGEN_MODEL=

LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://localhost:3000